{
	"name": "@agentz/monorepo",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*",
			"scripts"
		],
		"catalog": {
			"effect": "https://pkg.pr.new/Effect-TS/effect-smol/effect@8881a9b",
			"@effect/platform-node": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/platform-node@8881a9b",
			"@effect/sql-sqlite-bun": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/sql-sqlite-bun@8881a9b",
			"@effect/vitest": "https://pkg.pr.new/Effect-TS/effect-smol/@effect/vitest@8881a9b",
			"@effect/language-service": "0.75.1",
			"@types/bun": "^1.3.9",
			"@types/node": "^24.10.13",
			"tsdown": "^0.20.3",
			"typescript": "^5.7.3",
			"vitest": "^4.0.0"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "bun scripts/dev-runner.ts dev",
		"dev:server": "bun scripts/dev-runner.ts dev:server",
		"dev:web": "bun scripts/dev-runner.ts dev:web",
		"dev:desktop": "bun scripts/dev-runner.ts dev:desktop",
		"start": "bun run --cwd apps/server start",
		"start:desktop": "bun run --cwd apps/desktop start",
		"build": "bun run build:contracts && bun run --cwd apps/web build && bun run --cwd apps/server build && bun run --cwd apps/desktop build",
		"build:desktop": "bun run build:contracts && bun run --cwd apps/web build && bun run --cwd apps/server build && bun run --cwd apps/desktop build",
		"typecheck": "bun run --cwd packages/contracts typecheck && bun run --cwd packages/shared typecheck && bun run --cwd apps/server typecheck && bun run --cwd apps/web typecheck && bun run --cwd apps/desktop typecheck",
		"lint": "biome check .",
		"test": "bun run --cwd packages/contracts test && bun run --cwd packages/shared test && bun run --cwd apps/server test && bun run --cwd apps/web test && bun run --cwd apps/desktop test",
		"test:desktop-smoke": "bun run --cwd apps/desktop smoke-test",
		"fmt": "biome format --write .",
		"build:contracts": "bun run --cwd packages/contracts build",
		"dist:desktop:artifact": "bun scripts/build-desktop-artifact.ts",
		"dist:desktop:dmg": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg",
		"dist:desktop:dmg:arm64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
		"dist:desktop:dmg:x64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch x64",
		"dist:desktop:linux": "bun scripts/build-desktop-artifact.ts --platform linux --target AppImage --arch x64",
		"dist:desktop:win": "bun scripts/build-desktop-artifact.ts --platform win --target nsis --arch x64",
		"clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist apps/desktop/src-tauri/target",
		"sync:vscode-icons": "bun scripts/sync-vscode-icons.mjs",
		"prepare": "simple-git-hooks"
	},
	"simple-git-hooks": {
		"pre-commit": "bunx lint-staged && bun run typecheck"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml}": [
			"biome check --write"
		]
	},
	"devDependencies": {
		"@biomejs/biome": "^2.0.0",
		"@types/node": "catalog:",
		"lint-staged": "^16.1.6",
		"simple-git-hooks": "^2.13.1",
		"vitest": "catalog:"
	},
	"engines": {
		"bun": "^1.3.9",
		"node": "^24.13.1"
	},
	"packageManager": "bun@1.3.9",
	"msw": {
		"workerDirectory": [
			"apps/web/public"
		]
	}
}
