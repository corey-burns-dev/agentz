{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agents (Alpha)",
  "version": "0.0.4-alpha.1",
  "identifier": "com.agents.agents",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5733",
    "beforeBuildCommand": "",
    "frontendDist": "../../server/dist/client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Agents (Alpha)",
        "width": 1100,
        "height": 780,
        "minWidth": 840,
        "minHeight": 620,
        "decorations": false,
        "transparent": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../server/dist/": "apps/server/dist/"
    },
    "icon": ["../resources/icon.ico", "../resources/icon.png"]
  },
  "plugins": {}
}
